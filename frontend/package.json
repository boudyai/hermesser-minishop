{
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build:webapp:svelte:main": "vite build --config ./vite.config.mjs",
    "build:webapp:svelte:admin": "vite build --config ./vite.config.mjs --mode admin",
    "build:webapp:svelte:docs-demo": "vite build --config ./vite.config.mjs --mode docs-demo",
    "build:webapp:svelte": "npm run build:webapp:svelte:main && npm run build:webapp:svelte:admin",
    "build:docs-demo": "npm run build:webapp:svelte:docs-demo && npm run build:webapp:svelte:admin",
    "build:webapp:css": "npm run build:webapp:svelte",
    "build:webapp:js": "node ./scripts/build_subscription_webapp_js.mjs",
    "build:webapp": "npm run build:webapp:svelte && npm run build:webapp:js",
    "build": "npm run build:webapp",
    "generate:api-types": "npx --yes --package openapi-typescript@7.13.0 openapi-typescript ../docs/openapi.json -o src/lib/api/openapi.generated.ts && prettier --write src/lib/api/openapi.generated.ts",
    "check:runes": "node ./scripts/check-svelte-runes-only.mjs",
    "lint": "eslint src scripts",
    "lint:fix": "npm run lint:js:fix",
    "lint:js:fix": "eslint src scripts --fix",
    "format": "prettier --write \"src/**/*.{js,ts,svelte}\" \"scripts/**/*.mjs\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,svelte}\" \"scripts/**/*.mjs\"",
    "check:svelte": "svelte-check --tsconfig ./jsconfig.json",
    "typecheck:ts": "tsc --noEmit -p ./jsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check": "npm run check:runes && npm run lint && npm run check:svelte && npm run typecheck:ts && npm run format:check",
    "fix": "npm run format && npm run lint:js:fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@internationalized/date": "^3.12.1",
    "@neodrag/svelte": "^2.3.3",
    "@playwright/test": "^1.55.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/cli": "4.3.2",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/svelte-query": "^6.1.36",
    "@vincjo/datatables": "^2.8.1",
    "bits-ui": "^2.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^17.6.0",
    "lucide-svelte": "^1.0.1",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "svelte-eslint-parser": "^1.4.1",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "uplot": "^1.6.32",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  }
}
