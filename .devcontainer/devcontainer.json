{
  "name": "Remnawave Minishop",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  "postCreateCommand": "python -m pip install --upgrade pip && python -m pip install -r backend/requirements.txt -r requirements-dev.txt && npm --prefix frontend ci && npm --prefix docs-site ci",
  "forwardPorts": [8080, 8082, 3000, 3001],
  "portsAttributes": {
    "8080": {
      "label": "Mini Shop backend"
    },
    "8082": {
      "label": "Mini Shop frontend"
    },
    "3000": {
      "label": "Remnawave Panel"
    },
    "3001": {
      "label": "Remnawave health"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.mypy-type-checker",
        "charliermarsh.ruff",
        "svelte.svelte-vscode",
        "dbaeumer.vscode-eslint"
      ]
    }
  },
  "remoteUser": "vscode"
}
